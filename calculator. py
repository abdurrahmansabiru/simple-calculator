def add (a,b):
    return a+b
def subtract (a,b):
    return a-b
def multiply (a,b):
    return a*b
def division (a,b):
    if b==0:
        return "division not possible"
        
    
    else:
        return a/b
num1=int(input("Enter the first number"))
num2=int(input("Enter the second number:"))

